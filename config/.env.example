# ============================================================
# config/.env.example — Copy to config/.env and fill in values
# NEVER commit config/.env to git (it is in .gitignore)
# ============================================================

# ── Dhan broker credentials ──────────────────────────────────
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# ── Telegram notifications ───────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_1=
TELEGRAM_CHAT_ID_2=

# ── Bot mode: test | paper | live ────────────────────────────
BOT_MODE=paper

# ── Live trading interlock (bot/live_guard.py) ───────────────
# All three must be set correctly for live orders to be placed.
# Step 1: Set LIVE_TRADING_ENABLED=true only when ready
# Step 2: Pick a passphrase and generate its SHA256:
#         python -c "import hashlib; print(hashlib.sha256(b'YOUR-PHRASE').hexdigest())"
# Step 3: Paste the hash as LIVE_CONFIRM_TOKEN
# Step 4: Paste your passphrase as LIVE_CONFIRM_PASSPHRASE
LIVE_TRADING_ENABLED=false
LIVE_CONFIRM_TOKEN=
LIVE_CONFIRM_PASSPHRASE=

# ── Broker reconciliation on restart ─────────────────────────
# true = force-exit ghost positions found on Dhan at startup
# false = log only, do not touch
FORCE_EXIT_ON_RESTART=true

# ── Redis (optional — set REDIS_ENABLED=true to use) ─────────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Runtime overrides (all optional) ─────────────────────────
MAX_PER_SECTOR=2
NEW_TRADE_LOSS_PAUSE=-0.03
NIFTY50_SECURITY_ID=13
MONITOR_INTERVAL=60
SCAN_INTERVAL=30
AUTO_EXIT_TIME=15:15
AUTO_EXIT_THRESHOLD=-0.01
EOD_RESET_TIME=15:30
EXEC_MAX_SPREAD_PCT=0.0005
EXEC_MAX_DRIFT_PCT=0.0010
LIQUIDITY_MIN_VALUE=5000000
LIQUIDITY_LOOKBACK_BARS=3
ENTRY_REPRICE_SECS=10
ROTATION_MIN_PROFIT=0.005
ROTATION_MIN_EDGE=0.05
