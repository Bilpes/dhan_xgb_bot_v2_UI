# ============================================================
#  config/.env.example  —  Copy this to config/.env
#  Fill in your values. This is the ONLY file you ever edit.
# ============================================================

# ── Dhan API (Client ID never changes, token changes daily) ──
DHAN_CLIENT_ID=your_client_id_here
DHAN_ACCESS_TOKEN=paste_todays_token_here

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID_1=your_chat_id_here
TELEGRAM_CHAT_ID_2=second_person_chat_id_here

# ── Bot mode — THIS IS THE MAIN SWITCH ───────────────────────
#
#   test   → Scans all stocks ONCE, shows signals on Telegram,
#             exits immediately. No orders placed.
#             Use this first to verify the bot is working.
#
#   paper  → Full loop runs every 5 min during market hours.
#             Signals fire, Telegram alerts sent, P&L tracked.
#             But NO real orders placed on Dhan.
#             Run for 1 week before going live.
#
#   live   → Real orders placed on Dhan with your money.
#             Only switch here after paper trade works well.
#
BOT_MODE=test

# ── Auto exit settings (CNC safety) ─────────────────────────
AUTO_EXIT_TIME=-0.01
AUTO_EXIT_THRESHOLD=14:45
